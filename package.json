{
  "name": "firekylin",
  "bin": "pkg.js",
  "description": "A Simple & Fast Node Bloging Platform Base On ThinkJS 3.x & ReactJS & ES2015+",
  "version": "1.5.8",
  "author": "lizheming <i@imnerd.org>",
  "scripts": {
    "start": "node development.js",
    "copy-package": "node bin/copy_package.js",
    "dev": "vite",
    "build": "vite build",
    "watch": "vite build --watch",
    "preview": "vite preview",
    "lint": "eslint ./src ./*.js ./www/static/src/*.js ./www/static/src ./www/theme/firekylin --ignore-path .gitignore --cache --ext .js,.jsx || true",
    "lint-fix": "eslint ./src ./*.js ./www/static/src/*.js ./www/static/src ./www/theme/firekylin --ignore-path .gitignore --ext .js,.jsx --fix || true",
    "lint-break-on-errors": "echo '\n[INFO] Running ESLint...\n[INFO] (Autofix with `npm run lint-fix`)' && eslint ./src ./*.js ./www/static/src/*.js ./www/static/src ./www/theme/firekylin --ignore-path .gitignore --ext .js,.jsx",
    "check-extraneous-pkgs": "pnpm list --depth=0 && echo '[SUCCESS] No extraneous packages.' || (echo '[INFO] Pruning extraneous packages...\n' && pnpm prune)",
    "cron:rss": "npm start -- \"admin/cron/rss\"",
    "cron:comment": "npm start -- \"crontab/sync_comment\"",
    "build:pkg": "pkg . --out-path=dist/"
  },
  "pre-commit": [
    "lint-break-on-errors"
  ],
  "dependencies": {
    "ali-oss": "^6.2.1",
    "aws-sdk": "^2.814.0",
    "cos-nodejs-sdk-v5": "^2.5.6",
