    "markdown-toc": "^1.2.0",
    "marked": "^18.0.3",
    "marked-alert": "^2.1.2",
    "marked-footnote": "^1.4.0",
    "marked-highlight": "^2.2.4",
    "mathjax": "^4.1.2",
    "moment": "^2.29.4",
    "nodemailer": "^6.6.1",
    "on-finished": "^2.3.0",
    "phpass": "^0.1.1",
    "push-to-firekylin": "^0.2.3",
    "qiniu": "^7.3.0",
    "request": "^2.87.0",
    "request-promise-native": "^1.0.5",
    "semver": "^5.5.0",
    "speakeasy": "^2.0.0",
    "think-cache": "^1.0.0",
    "think-cache-file": "^1.0.8",
